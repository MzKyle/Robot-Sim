string main_pgm        # 主程序名称
string cur_pgm         # 当前运行的程序名称
int32 cur_seq          # 当前程序的步骤序号
string ncstatus        # NC（数控）状态（如"运行中"、"停止"等）
string mode            # 工作模式（如"自动"、"手动"、"远程"等）
float32 voltage1         # 第一路焊接电压（单位：V）
float32 current1         # 第一路焊接电流（单位：A）
float32 wire_speed1      # 第一路送丝速度（单位：mm/s）
int32 weld_detect1     # 第一路焊接检测状态（0=未检测，1=检测正常，2=异常）
float32 voltage2         # 第二路焊接电压（单位：V）
float32 current2         # 第二路焊接电流（单位：A）
float32 wire_speed2      # 第二路送丝速度（单位：mm/s）
int32 weld_detect2     # 第二路焊接检测状态（0=未检测，1=检测正常，2=异常）
int32 alarm            # 报警状态（0=无报警，1=有报警）
string alarm_msg       # 报警详情描述（如"电压过高"、"送丝故障"等）
int32 emg              # 急停状态（0=未触发，1=已触发急停）
int32 override         # 倍率值（如速度倍率，范围0-100%）
int32 weld_enable      # 焊接使能状态（0=禁用，1=使能）

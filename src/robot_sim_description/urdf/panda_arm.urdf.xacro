<?xml version="1.0"?>
<robot name="panda_arm" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:arg name="prefix" default=""/>
  <xacro:arg name="hardware_plugin" default="mock_components/GenericSystem"/>

  <xacro:property name="prefix" value="$(arg prefix)"/>
  <xacro:property name="hardware_plugin" value="$(arg hardware_plugin)"/>
  <xacro:property name="PI" value="3.141592653589793"/>
  <xacro:property name="mesh_root" value="package://robot_sim_description/models/panda_arm/meshes"/>
  <xacro:property name="camera_mesh" value="package://robot_sim_description/models/rgbd_camera/meshes/3dCamera.DAE"/>

  <material name="panda_white">
    <color rgba="0.92 0.92 0.88 1.0"/>
  </material>
  <material name="panda_dark">
    <color rgba="0.08 0.09 0.10 1.0"/>
  </material>
  <material name="sensor_blue">
    <color rgba="0.1 0.28 0.75 1.0"/>
  </material>

  <xacro:macro name="simple_inertial" params="mass:=1.0 ixx:=0.01 iyy:=0.01 izz:=0.01 xyz:='0 0 0' rpy:='0 0 0'">
    <inertial>
      <origin xyz="${xyz}" rpy="${rpy}"/>
      <mass value="${mass}"/>
      <inertia ixx="${ixx}" ixy="0.0" ixz="0.0" iyy="${iyy}" iyz="0.0" izz="${izz}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="mesh_link" params="name visual collision material:=panda_white mass:=1.0">
    <link name="${prefix}${name}">
      <visual>
        <geometry>
          <mesh filename="${mesh_root}/visual/${visual}"/>
        </geometry>
        <material name="${material}"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="${mesh_root}/collision/${collision}"/>
        </geometry>
      </collision>
      <xacro:simple_inertial mass="${mass}" ixx="0.01" iyy="0.01" izz="0.01"/>
    </link>
  </xacro:macro>

  <xacro:macro name="ros2_control_joint" params="name initial lower_limit upper_limit">
    <joint name="${prefix}${name}">
      <command_interface name="position">
        <param name="min">${lower_limit}</param>
        <param name="max">${upper_limit}</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">${initial}</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
  </xacro:macro>

  <link name="${prefix}world"/>

  <joint name="${prefix}panda_joint_world" type="fixed">
    <origin xyz="0.2 0 0.125" rpy="0 0 0"/>
    <parent link="${prefix}world"/>
    <child link="${prefix}panda_link0"/>
  </joint>

  <xacro:mesh_link name="panda_link0" visual="link0.dae" collision="link0.stl" material="panda_white" mass="2.8"/>
  <xacro:mesh_link name="panda_link1" visual="link1.dae" collision="link1.stl" material="panda_white" mass="2.6"/>
  <xacro:mesh_link name="panda_link2" visual="link2.dae" collision="link2.stl" material="panda_white" mass="2.7"/>
  <xacro:mesh_link name="panda_link3" visual="link3.dae" collision="link3.stl" material="panda_white" mass="2.3"/>
  <xacro:mesh_link name="panda_link4" visual="link4.dae" collision="link4.stl" material="panda_white" mass="2.3"/>
  <xacro:mesh_link name="panda_link5" visual="link5.dae" collision="link5.stl" material="panda_white" mass="2.4"/>
  <xacro:mesh_link name="panda_link6" visual="link6.dae" collision="link6.stl" material="panda_white" mass="1.8"/>
  <xacro:mesh_link name="panda_link7" visual="link7.dae" collision="link7.stl" material="panda_dark" mass="1.2"/>

  <joint name="${prefix}panda_joint1" type="revolute">
    <origin xyz="0 0 0.333" rpy="0 0 0"/>
    <parent link="${prefix}panda_link0"/>
    <child link="${prefix}panda_link1"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.897246558310587" upper="2.897246558310587" effort="87" velocity="2.617993877991494"/>
    <dynamics damping="21.75" friction="3.48"/>
  </joint>
  <joint name="${prefix}panda_joint2" type="revolute">
    <origin xyz="0 0 0" rpy="-1.570796326794897 0 0"/>
    <parent link="${prefix}panda_link1"/>
    <child link="${prefix}panda_link2"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.762782544514273" upper="1.762782544514273" effort="87" velocity="2.617993877991494"/>
    <dynamics damping="21.75" friction="3.48"/>
  </joint>
  <joint name="${prefix}panda_joint3" type="revolute">
    <origin xyz="0 -0.316 0" rpy="1.570796326794897 0 0"/>
    <parent link="${prefix}panda_link2"/>
    <child link="${prefix}panda_link3"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.897246558310587" upper="2.897246558310587" effort="87" velocity="2.617993877991494"/>
    <dynamics damping="21.75" friction="3.48"/>
  </joint>
  <joint name="${prefix}panda_joint4" type="revolute">
    <origin xyz="0.0825 0 0" rpy="1.570796326794897 0 0"/>
    <parent link="${prefix}panda_link3"/>
    <child link="${prefix}panda_link4"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.07177948351002" upper="-0.06981317007977318" effort="87" velocity="2.617993877991494"/>
    <dynamics damping="21.75" friction="3.48"/>
  </joint>
  <joint name="${prefix}panda_joint5" type="revolute">
    <origin xyz="-0.0825 0.384 0" rpy="-1.570796326794897 0 0"/>
    <parent link="${prefix}panda_link4"/>
    <child link="${prefix}panda_link5"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.897246558310587" upper="2.897246558310587" effort="12" velocity="3.141592653589793"/>
    <dynamics damping="3.0" friction="0.48"/>
  </joint>
  <joint name="${prefix}panda_joint6" type="revolute">
    <origin xyz="0 0 0" rpy="1.570796326794897 0 0"/>
    <parent link="${prefix}panda_link5"/>
    <child link="${prefix}panda_link6"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.0174532925199433" upper="3.752457891787809" effort="12" velocity="3.141592653589793"/>
    <dynamics damping="3.0" friction="0.48"/>
  </joint>
  <joint name="${prefix}panda_joint7" type="revolute">
    <origin xyz="0.088 0 0" rpy="1.570796326794897 0 0"/>
    <parent link="${prefix}panda_link6"/>
    <child link="${prefix}panda_link7"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.897246558310587" upper="2.897246558310587" effort="12" velocity="3.141592653589793"/>
    <dynamics damping="3.0" friction="0.48"/>
  </joint>

  <xacro:mesh_link name="panda_hand" visual="hand.dae" collision="hand.stl" material="panda_dark" mass="0.14"/>
  <joint name="${prefix}panda_hand_joint" type="fixed">
    <origin xyz="0 0 0.107" rpy="0 0 -0.7853981633974483"/>
    <parent link="${prefix}panda_link7"/>
    <child link="${prefix}panda_hand"/>
  </joint>

  <link name="${prefix}panda_link8">
    <xacro:simple_inertial mass="0.01" ixx="0.0001" iyy="0.0001" izz="0.0001"/>
  </link>
  <joint name="${prefix}end_effector_frame_fixed_joint" type="fixed">
    <origin xyz="0 0 0.103" rpy="0 0 0"/>
    <parent link="${prefix}panda_hand"/>
    <child link="${prefix}panda_link8"/>
  </joint>

  <link name="${prefix}panda_leftfinger">
    <visual>
      <geometry>
        <mesh filename="${mesh_root}/visual/finger.dae"/>
      </geometry>
      <material name="panda_dark"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="${mesh_root}/collision/finger.stl"/>
      </geometry>
    </collision>
    <xacro:simple_inertial mass="0.22" ixx="0.0001" iyy="0.0001" izz="0.0001"/>
  </link>
  <link name="${prefix}panda_rightfinger">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 ${PI}"/>
      <geometry>
        <mesh filename="${mesh_root}/visual/finger.dae"/>
      </geometry>
      <material name="panda_dark"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 ${PI}"/>
      <geometry>
        <mesh filename="${mesh_root}/collision/finger.stl"/>
      </geometry>
    </collision>
    <xacro:simple_inertial mass="0.22" ixx="0.0001" iyy="0.0001" izz="0.0001"/>
  </link>

  <joint name="${prefix}panda_finger_joint1" type="prismatic">
    <origin xyz="0 0 0.0584" rpy="0 0 0"/>
    <parent link="${prefix}panda_hand"/>
    <child link="${prefix}panda_leftfinger"/>
    <axis xyz="0 1 0"/>
    <limit lower="0.0" upper="0.04" effort="20" velocity="0.2"/>
    <dynamics damping="10" friction="0.5"/>
  </joint>
  <joint name="${prefix}panda_finger_joint2" type="prismatic">
    <origin xyz="0 0 0.0584" rpy="0 0 0"/>
    <parent link="${prefix}panda_hand"/>
    <child link="${prefix}panda_rightfinger"/>
    <axis xyz="0 -1 0"/>
    <limit lower="0.0" upper="0.04" effort="20" velocity="0.2"/>
    <dynamics damping="10" friction="0.5"/>
  </joint>

  <link name="${prefix}camera_mount">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 1.5707963267948966"/>
      <geometry>
        <mesh filename="${camera_mesh}"/>
      </geometry>
      <material name="sensor_blue"/>
    </visual>
    <collision>
      <origin xyz="0.02 0 0.034" rpy="0 0 1.5707963267948966"/>
      <geometry>
        <box size="0.165 0.040 0.030"/>
      </geometry>
    </collision>
    <xacro:simple_inertial mass="0.3" ixx="0.0002" iyy="0.0008" izz="0.0008"/>
  </link>
  <joint name="${prefix}panda_link8_camera_mount" type="fixed">
    <origin xyz="0.10 0 -0.10" rpy="0 -0.7853981633974483 3.141592653589793"/>
    <parent link="${prefix}panda_link8"/>
    <child link="${prefix}camera_mount"/>
  </joint>

  <link name="${prefix}camera_color_frame"/>
  <joint name="${prefix}camera_color_frame_joint" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="${prefix}camera_mount"/>
    <child link="${prefix}camera_color_frame"/>
  </joint>
  <link name="${prefix}rgbd_camera_frame"/>
  <joint name="${prefix}rgbd_camera_frame_joint" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="${prefix}camera_mount"/>
    <child link="${prefix}rgbd_camera_frame"/>
  </joint>
  <link name="${prefix}lidar_2d_frame"/>
  <joint name="${prefix}lidar_2d_frame_joint" type="fixed">
    <origin xyz="0 0 0.035" rpy="0 0 0"/>
    <parent link="${prefix}camera_mount"/>
    <child link="${prefix}lidar_2d_frame"/>
  </joint>
  <link name="${prefix}lidar_3d_frame"/>
  <joint name="${prefix}lidar_3d_frame_joint" type="fixed">
    <origin xyz="0 0 0.055" rpy="0 0 0"/>
    <parent link="${prefix}camera_mount"/>
    <child link="${prefix}lidar_3d_frame"/>
  </joint>
  <link name="${prefix}imu_link"/>
  <joint name="${prefix}imu_joint" type="fixed">
    <origin xyz="0 0 0.02" rpy="0 0 0"/>
    <parent link="${prefix}camera_mount"/>
    <child link="${prefix}imu_link"/>
  </joint>

  <ros2_control name="${prefix}PandaMockSystem" type="system">
    <hardware>
      <plugin>${hardware_plugin}</plugin>
    </hardware>
    <xacro:ros2_control_joint name="panda_joint1" initial="0.0" lower_limit="-2.897246558310587" upper_limit="2.897246558310587"/>
    <xacro:ros2_control_joint name="panda_joint2" initial="-0.7853981633974483" lower_limit="-1.762782544514273" upper_limit="1.762782544514273"/>
    <xacro:ros2_control_joint name="panda_joint3" initial="0.0" lower_limit="-2.897246558310587" upper_limit="2.897246558310587"/>
    <xacro:ros2_control_joint name="panda_joint4" initial="-2.356194490192345" lower_limit="-3.07177948351002" upper_limit="-0.06981317007977318"/>
    <xacro:ros2_control_joint name="panda_joint5" initial="0.0" lower_limit="-2.897246558310587" upper_limit="2.897246558310587"/>
    <xacro:ros2_control_joint name="panda_joint6" initial="1.5707963267948966" lower_limit="-0.0174532925199433" upper_limit="3.752457891787809"/>
    <xacro:ros2_control_joint name="panda_joint7" initial="0.7853981633974483" lower_limit="-2.897246558310587" upper_limit="2.897246558310587"/>
    <xacro:ros2_control_joint name="panda_finger_joint1" initial="0.02" lower_limit="0.0" upper_limit="0.04"/>
    <xacro:ros2_control_joint name="panda_finger_joint2" initial="0.02" lower_limit="0.0" upper_limit="0.04"/>
  </ros2_control>
</robot>

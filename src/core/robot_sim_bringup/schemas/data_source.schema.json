{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://robot-sim.local/schemas/data_source.schema.json",
  "title": "robot_sim data source",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema", "kind", "name", "type"],
  "properties": {
    "schema": { "const": 4 },
    "kind": { "const": "data_source" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "type": {
      "enum": ["image_sequence", "video", "rosbag", "csv", "json", "message_sequence", "service_source"]
    },
    "path": { "type": "string" },
    "package": { "type": "string" },
    "message_type": { "type": "string" },
    "topic": { "type": "string" },
    "rate_hz": { "type": "number" },
    "loop": { "type": "boolean" },
    "repeat": { "type": "boolean" },
    "qos_depth": { "type": "integer" },
    "messages": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "records_key": { "type": "string" },
    "field_map": {
      "type": "object",
      "additionalProperties": true
    },
    "glob": { "type": "string" },
    "images": {
      "type": "array",
      "items": { "type": "string" }
    },
    "image": { "type": "string" },
    "image_topic": { "type": "string" },
    "camera_info_topic": { "type": "string" },
    "frame_id": { "type": "string" },
    "encoding": { "type": "string" },
    "camera_info": {
      "type": "object",
      "additionalProperties": true
    },
    "fps": { "type": "number" },
    "start_sec": { "type": "number" },
    "duration_sec": { "type": "number" },
    "topics": {
      "type": "array",
      "items": { "type": "string" }
    },
    "remap": {
      "type": "object",
      "additionalProperties": true
    },
    "clock": { "type": "boolean" },
    "service": { "type": "string" },
    "service_type": { "type": "string" },
    "response": {
      "type": "object",
      "additionalProperties": true
    },
    "responses": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "default_response": {
      "type": "object",
      "additionalProperties": true
    },
    "response_sequence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "delay_sec": { "type": "number" },
    "proxy": {
      "type": "object",
      "additionalProperties": true
    }
  }
}

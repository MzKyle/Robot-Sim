{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://robot-sim.local/schemas/sim_profile.schema.json",
  "title": "robot_sim sim profile",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema",
    "kind",
    "name",
    "metadata",
    "capabilities",
    "end_effector",
    "layouts",
    "robot",
    "worlds",
    "gazebo",
    "control",
    "bridges",
    "bridge_groups",
    "sensors",
    "smoke"
  ],
  "properties": {
    "schema": { "const": 3 },
    "kind": { "const": "sim_profile" },
    "name": { "type": "string", "minLength": 1 },
    "metadata": {
      "type": "object",
      "required": ["package", "robot_name"],
      "properties": {
        "package": { "type": "string", "minLength": 1 },
        "robot_name": { "type": "string", "minLength": 1 },
        "vendor": { "type": "string" },
        "model": { "type": "string" }
      },
      "additionalProperties": true
    },
    "capabilities": {
      "type": "object",
      "required": ["task_families", "sensors"],
      "properties": {
        "task_families": {
          "type": "array",
          "items": {
            "enum": [
              "empty_motion",
              "obstacle_clearance",
              "fixture_to_pallet",
              "pick_place",
              "sensor_calibration",
              "conveyor_sorting"
            ]
          }
        },
        "sensors": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "end_effector": {
      "type": "object",
      "required": ["planning_group", "tool_link"],
      "properties": {
        "planning_group": { "type": "string", "minLength": 1 },
        "tool_link": { "type": "string", "minLength": 1 },
        "base_frame": { "type": "string" },
        "gripper": {
          "type": "object",
          "required": ["controller"],
          "properties": {
            "controller": { "type": "string", "minLength": 1 },
            "open_positions": {
              "type": "array",
              "items": { "type": "number" }
            },
            "closed_positions": {
              "type": "array",
              "items": { "type": "number" }
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "layouts": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["world", "namespaces"]
      }
    },
    "robot": {
      "type": "object",
      "required": ["xacro", "spawn_name", "spawn_node_name", "allow_renaming"],
      "properties": {
        "xacro": { "$ref": "#/$defs/package_ref" }
      }
    },
    "worlds": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "oneOf": [
          {
            "type": "object",
            "required": ["scene"],
            "properties": { "scene": { "$ref": "#/$defs/package_ref" } },
            "additionalProperties": false
          },
          {
            "type": "object",
            "required": ["world_preset"],
            "properties": { "world_preset": { "$ref": "#/$defs/package_ref" } },
            "additionalProperties": false
          },
          {
            "type": "object",
            "required": ["file"],
            "properties": { "file": { "$ref": "#/$defs/package_ref" } },
            "additionalProperties": false
          }
        ]
      }
    },
    "gazebo": {
      "type": "object",
      "required": ["launch", "gz_version", "args", "resource_paths"]
    },
    "control": {
      "type": "object",
      "required": ["controllers_file", "controller_manager_name", "hardware_plugins", "spawners"]
    },
    "bridges": {
      "type": "array",
      "items": { "type": "string" }
    },
    "bridge_groups": {
      "type": "object",
      "minProperties": 1
    },
    "sensors": {
      "type": "object"
    },
    "smoke": {
      "type": "object",
      "required": ["controllers", "sensors", "tf"]
    }
  },
  "$defs": {
    "package_ref": {
      "type": "object",
      "required": ["package", "path"],
      "properties": {
        "package": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "name": { "type": "string" },
        "variant": { "type": "string" },
        "parameters": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  }
}

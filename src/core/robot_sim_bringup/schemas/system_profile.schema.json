{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://robot-sim.local/schemas/system_profile.schema.json",
  "title": "robot_sim system profile",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "kind", "name", "description", "system"],
  "properties": {
    "schema": { "const": 4 },
    "kind": { "const": "system_profile" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "system": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "default": "ros2_pipeline" },
        "env": {
          "type": "object",
          "additionalProperties": true
        },
        "startup_delay_sec": { "type": "number" },
        "processes": {
          "type": "array",
          "items": { "$ref": "#/$defs/process" }
        }
      }
    }
  },
  "$defs": {
    "process": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "command"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "command": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "background": { "type": "boolean" },
        "timeout_sec": { "type": "number" },
        "required": { "type": "boolean" },
        "env": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}

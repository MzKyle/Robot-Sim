{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://robot-sim.local/schemas/world_preset.schema.json",
  "title": "robot_sim world preset",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema", "kind", "name", "world_name", "base", "scenario", "assets"],
  "properties": {
    "schema": { "const": 3 },
    "kind": { "const": "world_preset" },
    "name": { "type": "string", "minLength": 1 },
    "world_name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "base": { "$ref": "#/$defs/package_ref" },
    "scenario": {
      "type": "object",
      "required": ["type", "task_family"],
      "properties": {
        "type": { "type": "string" },
        "task_family": { "type": "string" }
      }
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "package", "path", "pose", "tags"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "package": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "pose": {
            "type": "array",
            "minItems": 6,
            "maxItems": 6,
            "items": { "type": "number" }
          },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  },
  "$defs": {
    "package_ref": {
      "type": "object",
      "required": ["package", "path"],
      "properties": {
        "package": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 }
      }
    }
  }
}

#!/usr/bin/env python3
import rclpy
from rclpy.node import Node
from sensor_msgs.msg import JointState
from std_msgs.msg import Float64


class JointStateToGzJointCmd(Node):
    JOINT_LIMITS = {
        "panda_joint1": (-2.897246558310587, 2.897246558310587),
        "panda_joint2": (-1.762782544514273, 1.762782544514273),
        "panda_joint3": (-2.897246558310587, 2.897246558310587),
        "panda_joint4": (-3.07177948351002, -0.06981317007977318),
        "panda_joint5": (-2.897246558310587, 2.897246558310587),
        "panda_joint6": (-0.0174532925199433, 3.752457891787809),
        "panda_joint7": (-2.897246558310587, 2.897246558310587),
        "panda_finger_joint1": (0.0, 0.04),
        "panda_finger_joint2": (0.0, 0.04),
    }

    DEFAULT_POSITIONS = {
        "panda_joint1": 0.0,
        "panda_joint2": -0.7853981633974483,
        "panda_joint3": 0.0,
        "panda_joint4": -2.356194490192345,
        "panda_joint5": 0.0,
        "panda_joint6": 1.5707963267948966,
        "panda_joint7": 0.7853981633974483,
        "panda_finger_joint1": 0.02,
        "panda_finger_joint2": 0.02,
    }

    def __init__(self):
        super().__init__("joint_state_to_gz_joint_cmd")
        self.declare_parameter("model_name", "panda")
        self.declare_parameter("joint_state_topic", "/joint_states")
        self.declare_parameter("publish_rate", 50.0)

        self.model_name = self.get_parameter("model_name").value
        self.positions = dict(self.DEFAULT_POSITIONS)
        self.received_state = False
        publish_rate = max(1.0, float(self.get_parameter("publish_rate").value))
        joint_state_topic = self.get_parameter("joint_state_topic").value

        self.command_publishers = {
            name: self.create_publisher(
                Float64,
                f"/{self.model_name}/joint/{name}/cmd_pos",
                10,
            )
            for name in self.JOINT_LIMITS
        }
        self.create_subscription(JointState, joint_state_topic, self._on_joint_state, 10)
        self.create_timer(1.0 / publish_rate, self._publish_commands)

        self.get_logger().info(
            f"Following {joint_state_topic}; publishing Gazebo joint commands "
            f"for model {self.model_name}"
        )

    def _on_joint_state(self, msg):
        matched = False
        for name, position in zip(msg.name, msg.position):
            if name not in self.positions:
                continue
            lower, upper = self.JOINT_LIMITS[name]
            self.positions[name] = min(max(float(position), lower), upper)
            matched = True
        if matched and not self.received_state:
            self.received_state = True
            self.get_logger().info("Received joint states; Gazebo commands are synchronized")

    def _publish_commands(self):
        for name, position in self.positions.items():
            msg = Float64()
            msg.data = float(position)
            self.command_publishers[name].publish(msg)


def main():
    rclpy.init()
    node = JointStateToGzJointCmd()
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    finally:
        node.destroy_node()
        if rclpy.ok():
            rclpy.shutdown()


if __name__ == "__main__":
    main()

<?xml version="1.0"?>
<robot name="fanuc_m20id12l" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:arg name="prefix" default=""/>
  <xacro:arg name="mesh_root" default="package://robot_sim_fanuc_description/models/m20id12l/meshes"/>
  <xacro:arg name="hardware_plugin" default="mock_components/GenericSystem"/>
  <xacro:arg name="controllers_file" default=""/>
  <xacro:arg name="controller_manager_name" default="controller_manager"/>
  <xacro:arg name="use_gz_ros2_control" default="false"/>
  <xacro:arg name="ros_namespace" default=""/>
  <xacro:arg name="enable_camera" default="false"/>
  <xacro:arg name="enable_depth" default="false"/>
  <xacro:arg name="enable_lidar" default="false"/>
  <xacro:arg name="enable_imu" default="false"/>

  <xacro:property name="prefix" value="$(arg prefix)"/>
  <xacro:property name="mesh_root" value="$(arg mesh_root)"/>
  <xacro:property name="hardware_plugin" value="$(arg hardware_plugin)"/>
  <xacro:property name="controllers_file" value="$(arg controllers_file)"/>
  <xacro:property name="controller_manager_name" value="$(arg controller_manager_name)"/>
  <xacro:property name="ros_namespace" value="$(arg ros_namespace)"/>
  <xacro:property name="PI" value="3.141592653589793"/>

  <material name="fanuc_black">
    <color rgba="0.02 0.02 0.02 1.0"/>
  </material>

  <xacro:macro name="simple_inertial" params="mass:=1.0 ixx:=0.02 iyy:=0.02 izz:=0.02 xyz:='0 0 0' rpy:='0 0 0'">
    <inertial>
      <origin xyz="${xyz}" rpy="${rpy}"/>
      <mass value="${mass}"/>
      <inertia ixx="${ixx}" ixy="0.0" ixz="0.0" iyy="${iyy}" iyz="0.0" izz="${izz}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="fanuc_inertial" params="mass xyz ixx ixy ixz iyy iyz izz">
    <inertial>
      <origin xyz="${xyz}" rpy="0 0 0"/>
      <mass value="${mass}"/>
      <inertia ixx="${ixx}" ixy="${ixy}" ixz="${ixz}" iyy="${iyy}" iyz="${iyz}" izz="${izz}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="mesh_link" params="name visual collision mass inertial_xyz ixx ixy ixz iyy iyz izz">
    <link name="${prefix}${name}">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="${mesh_root}/visual/${visual}"/>
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="${mesh_root}/collision/${collision}"/>
        </geometry>
      </collision>
      <xacro:fanuc_inertial
        mass="${mass}"
        xyz="${inertial_xyz}"
        ixx="${ixx}"
        ixy="${ixy}"
        ixz="${ixz}"
        iyy="${iyy}"
        iyz="${iyz}"
        izz="${izz}"
      />
    </link>
  </xacro:macro>

  <xacro:macro name="control_joint" params="name initial lower upper">
    <joint name="${prefix}${name}">
      <command_interface name="position">
        <param name="min">${lower}</param>
        <param name="max">${upper}</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">${initial}</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
  </xacro:macro>

  <link name="${prefix}world"/>

  <joint name="${prefix}world_to_base_link" type="fixed">
    <origin xyz="0.2 0 0" rpy="0 0 0"/>
    <parent link="${prefix}world"/>
    <child link="${prefix}base_link"/>
  </joint>

  <xacro:mesh_link name="base_link" visual="base.dae" collision="base.stl" mass="45.3" inertial_xyz="-0.0767 0.00288 0.109" ixx="0.492" ixy="0.0288" ixz="0.0135" iyy="1.09" iyz="0.0000531" izz="1.15"/>
  <xacro:mesh_link name="link_1" visual="j1.dae" collision="j1.stl" mass="62.2" inertial_xyz="0.0158 -0.0106 -0.0831" ixx="1.33" ixy="0.132" ixz="-0.0412" iyy="1.1" iyz="-0.107" izz="1.29"/>
  <xacro:mesh_link name="link_2" visual="j2.dae" collision="j2.stl" mass="65.1" inertial_xyz="-0.0343 -0.172 0.38" ixx="4.81" ixy="-0.0801" ixz="0.0448" iyy="4.93" iyz="-0.117" izz="0.53"/>
  <xacro:mesh_link name="link_3" visual="j3.dae" collision="j3.stl" mass="52.3" inertial_xyz="0.134 0.00796 0.103" ixx="0.892" ixy="-0.0776" ixz="-0.291" iyy="1.12" iyz="-0.0381" izz="1.05"/>
  <xacro:mesh_link name="link_4" visual="j4.dae" collision="j4.stl" mass="23.5" inertial_xyz="0.827 -0.0285 -0.00109" ixx="0.0677" ixy="0.112" ixz="0.00237" iyy="1.86" iyz="-0.000766" izz="1.88"/>
  <xacro:mesh_link name="link_5" visual="j5.dae" collision="j5.stl" mass="1.26" inertial_xyz="0.0214 -0.015 0.0000000000494" ixx="0.00187" ixy="-0.000425" ixz="0.00000000000169" iyy="0.00207" iyz="0.00000000000153" izz="0.00205"/>
  <xacro:mesh_link name="link_6" visual="j6.dae" collision="j6.stl" mass="0.243" inertial_xyz="0.0537 0.000000457 0.00000541" ixx="0.000142" ixy="-0.000000000125" ixz="-0.00000000866" iyy="0.00011" iyz="-0.00000000000431" izz="0.00011"/>

  <joint name="${prefix}joint_1" type="revolute">
    <origin xyz="0 0 0.425" rpy="0 0 0"/>
    <parent link="${prefix}base_link"/>
    <child link="${prefix}link_1"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.228859" upper="3.228859" effort="7000" velocity="3.665191"/>
    <dynamics damping="18.0" friction="2.0"/>
  </joint>
  <joint name="${prefix}joint_2" type="revolute">
    <origin xyz="0.075 0 0" rpy="0 0 0"/>
    <parent link="${prefix}link_1"/>
    <child link="${prefix}link_2"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.745329" upper="2.792527" effort="8000" velocity="3.665191"/>
    <dynamics damping="18.0" friction="2.0"/>
  </joint>
  <joint name="${prefix}joint_3" type="revolute">
    <origin xyz="0 0 0.840" rpy="0 0 0"/>
    <parent link="${prefix}link_2"/>
    <child link="${prefix}link_3"/>
    <axis xyz="0 -1 0"/>
    <limit lower="-1.570796" upper="3.839724" effort="4000" velocity="4.625123"/>
    <dynamics damping="15.0" friction="1.6"/>
  </joint>
  <joint name="${prefix}joint_4" type="revolute">
    <origin xyz="0 0 0.215" rpy="0 0 0"/>
    <parent link="${prefix}link_3"/>
    <child link="${prefix}link_4"/>
    <axis xyz="-1 0 0"/>
    <limit lower="-3.490659" upper="3.490659" effort="100" velocity="7.330383"/>
    <dynamics damping="8.0" friction="1.0"/>
  </joint>
  <joint name="${prefix}joint_5" type="revolute">
    <origin xyz="1.340 0 0" rpy="0 0 0"/>
    <parent link="${prefix}link_4"/>
    <child link="${prefix}link_5"/>
    <axis xyz="0 -1 0"/>
    <limit lower="-3.141575" upper="3.141575" effort="100" velocity="7.853982"/>
    <dynamics damping="6.0" friction="0.8"/>
  </joint>
  <joint name="${prefix}joint_6" type="revolute">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="${prefix}link_5"/>
    <child link="${prefix}link_6"/>
    <axis xyz="-1 0 0"/>
    <limit lower="-7.853982" upper="7.853982" effort="50" velocity="12.566371"/>
    <dynamics damping="4.0" friction="0.6"/>
  </joint>

  <link name="${prefix}base">
    <xacro:simple_inertial mass="0.01" ixx="0.0001" iyy="0.0001" izz="0.0001"/>
  </link>
  <joint name="${prefix}base_link_to_base" type="fixed">
    <origin xyz="0 0 0.425" rpy="0 0 0"/>
    <parent link="${prefix}base_link"/>
    <child link="${prefix}base"/>
  </joint>

  <link name="${prefix}flange">
    <xacro:simple_inertial mass="0.01" ixx="0.0001" iyy="0.0001" izz="0.0001"/>
  </link>
  <joint name="${prefix}joint_6_to_flange" type="fixed">
    <origin xyz="0.075 0 0" rpy="0 0 0"/>
    <parent link="${prefix}link_6"/>
    <child link="${prefix}flange"/>
  </joint>

  <link name="${prefix}tool0">
    <xacro:simple_inertial mass="0.01" ixx="0.0001" iyy="0.0001" izz="0.0001"/>
  </link>
  <joint name="${prefix}flange_to_tool0" type="fixed">
    <origin xyz="0 0 0" rpy="${PI} ${-PI / 2.0} 0"/>
    <parent link="${prefix}flange"/>
    <child link="${prefix}tool0"/>
  </joint>

  <link name="${prefix}camera_mount">
    <visual>
      <origin xyz="0.035 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.16 0.05 0.05"/>
      </geometry>
      <material name="fanuc_black"/>
    </visual>
    <collision>
      <origin xyz="0.035 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.16 0.05 0.05"/>
      </geometry>
    </collision>
    <xacro:simple_inertial mass="0.25" ixx="0.0004" iyy="0.0008" izz="0.0008"/>
  </link>
  <joint name="${prefix}tool0_to_camera_mount" type="fixed">
    <origin xyz="0.12 0 0.02" rpy="0 -0.55 0"/>
    <parent link="${prefix}tool0"/>
    <child link="${prefix}camera_mount"/>
  </joint>

  <link name="${prefix}camera_color_frame"/>
  <joint name="${prefix}camera_color_frame_joint" type="fixed">
    <origin xyz="0.08 0 0" rpy="0 0 0"/>
    <parent link="${prefix}camera_mount"/>
    <child link="${prefix}camera_color_frame"/>
  </joint>
  <link name="${prefix}rgbd_camera_frame"/>
  <joint name="${prefix}rgbd_camera_frame_joint" type="fixed">
    <origin xyz="0.08 0 0" rpy="0 0 0"/>
    <parent link="${prefix}camera_mount"/>
    <child link="${prefix}rgbd_camera_frame"/>
  </joint>
  <link name="${prefix}lidar_2d_frame"/>
  <joint name="${prefix}lidar_2d_frame_joint" type="fixed">
    <origin xyz="0.08 0 0.03" rpy="0 0 0"/>
    <parent link="${prefix}camera_mount"/>
    <child link="${prefix}lidar_2d_frame"/>
  </joint>
  <link name="${prefix}lidar_3d_frame"/>
  <joint name="${prefix}lidar_3d_frame_joint" type="fixed">
    <origin xyz="0.08 0 0.05" rpy="0 0 0"/>
    <parent link="${prefix}camera_mount"/>
    <child link="${prefix}lidar_3d_frame"/>
  </joint>
  <link name="${prefix}imu_link"/>
  <joint name="${prefix}imu_joint" type="fixed">
    <origin xyz="0.02 0 0" rpy="0 0 0"/>
    <parent link="${prefix}camera_mount"/>
    <child link="${prefix}imu_link"/>
  </joint>

  <xacro:if value="$(arg enable_camera)">
    <gazebo reference="${prefix}camera_mount">
      <sensor name="color_camera" type="camera">
        <pose>0.08 0 0 0 0 0</pose>
        <topic>/camera/color/image_raw</topic>
        <camera>
          <horizontal_fov>1.047</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.03</near>
            <far>100.0</far>
          </clip>
        </camera>
        <always_on>true</always_on>
        <update_rate>30</update_rate>
        <visualize>true</visualize>
      </sensor>
    </gazebo>
  </xacro:if>

  <xacro:if value="$(arg enable_depth)">
    <gazebo reference="${prefix}camera_mount">
      <sensor name="rgbd_camera" type="rgbd_camera">
        <pose>0.08 0 0 0 0 0</pose>
        <topic>/camera/depth</topic>
        <camera>
          <horizontal_fov>1.047</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.03</near>
            <far>30.0</far>
          </clip>
        </camera>
        <always_on>true</always_on>
        <update_rate>15</update_rate>
        <visualize>false</visualize>
      </sensor>
    </gazebo>
  </xacro:if>

  <xacro:if value="$(arg enable_lidar)">
    <gazebo reference="${prefix}camera_mount">
      <sensor name="lidar_2d" type="gpu_lidar">
        <pose>0.08 0 0.03 0 0 0</pose>
        <topic>/scan</topic>
        <update_rate>20</update_rate>
        <lidar>
          <scan>
            <horizontal>
              <samples>720</samples>
              <resolution>1</resolution>
              <min_angle>-1.5707963267948966</min_angle>
              <max_angle>1.5707963267948966</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.05</min>
            <max>12.0</max>
            <resolution>0.01</resolution>
          </range>
        </lidar>
        <visualize>false</visualize>
      </sensor>
    </gazebo>

    <gazebo reference="${prefix}camera_mount">
      <sensor name="lidar_3d" type="gpu_lidar">
        <pose>0.08 0 0.05 0 0 0</pose>
        <topic>/lidar</topic>
        <update_rate>10</update_rate>
        <lidar>
          <scan>
            <horizontal>
              <samples>320</samples>
              <resolution>1</resolution>
              <min_angle>-1.5707963267948966</min_angle>
              <max_angle>1.5707963267948966</max_angle>
            </horizontal>
            <vertical>
              <samples>32</samples>
              <resolution>1</resolution>
              <min_angle>-0.5235987755982988</min_angle>
              <max_angle>0.5235987755982988</max_angle>
            </vertical>
          </scan>
          <range>
            <min>0.05</min>
            <max>15.0</max>
            <resolution>0.02</resolution>
          </range>
        </lidar>
        <visualize>false</visualize>
      </sensor>
    </gazebo>
  </xacro:if>

  <xacro:if value="$(arg enable_imu)">
    <gazebo reference="${prefix}camera_mount">
      <sensor name="imu" type="imu">
        <pose>0.02 0 0 0 0 0</pose>
        <topic>/imu/data</topic>
        <always_on>true</always_on>
        <update_rate>100</update_rate>
        <visualize>false</visualize>
      </sensor>
    </gazebo>
  </xacro:if>

  <xacro:if value="$(arg use_gz_ros2_control)">
    <gazebo>
      <plugin filename="libgz_ros2_control-system.so" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
        <parameters>${controllers_file}</parameters>
        <robot_param>robot_description</robot_param>
        <robot_param_node>robot_state_publisher</robot_param_node>
        <controller_manager_name>${controller_manager_name}</controller_manager_name>
        <ros>
          <namespace>${ros_namespace}</namespace>
        </ros>
      </plugin>
    </gazebo>
  </xacro:if>

  <ros2_control name="${prefix}FanucM20iD12LSystem" type="system">
    <hardware>
      <plugin>${hardware_plugin}</plugin>
    </hardware>
    <xacro:control_joint name="joint_1" initial="0.0" lower="-3.228859" upper="3.228859"/>
    <xacro:control_joint name="joint_2" initial="-0.45" lower="-1.745329" upper="2.792527"/>
    <xacro:control_joint name="joint_3" initial="0.75" lower="-1.570796" upper="3.839724"/>
    <xacro:control_joint name="joint_4" initial="0.0" lower="-3.490659" upper="3.490659"/>
    <xacro:control_joint name="joint_5" initial="-0.35" lower="-3.141575" upper="3.141575"/>
    <xacro:control_joint name="joint_6" initial="0.0" lower="-7.853982" upper="7.853982"/>
  </ros2_control>
</robot>

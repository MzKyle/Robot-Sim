#!/usr/bin/env python3
"""
Convert joint_state_publisher_gui /joint_states into Gazebo joint position commands.
"""
import math

import rclpy
from rclpy.node import Node
from sensor_msgs.msg import JointState
from std_msgs.msg import Float64


class JointStateToGazeboJointCommand(Node):
    JOINT_LIMITS = {
        "joint_1": (-math.pi, math.pi),
        "joint_2": (-1.7453292519943295, 2.443460952792061),
        "joint_3": (-2.600540585471551, 5.585053606381854),
        "joint_4": (-3.490658503988659, 3.490658503988659),
        "joint_5": (-2.530727415391778, 2.530727415391778),
        "joint_6": (-4.71238898038469, 4.71238898038469),
    }

    def __init__(self):
        super().__init__("joint_state_to_gz_joint_cmd")
        self.declare_parameter("model_name", "fanuc_m20i")
        self.declare_parameter("joint_state_topic", "/joint_states")
        self.declare_parameter("publish_rate", 30.0)

        self.model_name = self.get_parameter("model_name").value
        self.joint_state_topic = self.get_parameter("joint_state_topic").value
        publish_rate = max(1.0, float(self.get_parameter("publish_rate").value))

        self.joint_names = list(self.JOINT_LIMITS.keys())
        self.positions = {name: 0.0 for name in self.joint_names}
        self._received_joint_state = False
        self._cmd_publishers = {
            name: self.create_publisher(
                Float64,
                f"/{self.model_name}/{name}/cmd_pos",
                10,
            )
            for name in self.joint_names
        }

        self.create_subscription(JointState, self.joint_state_topic, self._on_joint_state, 10)
        self.create_timer(1.0 / publish_rate, self._publish_commands)

        topics = ", ".join(f"/{self.model_name}/{name}/cmd_pos" for name in self.joint_names)
        self.get_logger().info(
            f"Listening {self.joint_state_topic}; publishing Gazebo joint position commands: {topics}"
        )

    def _on_joint_state(self, msg: JointState):
        matched = False
        for name, position in zip(msg.name, msg.position):
            if name not in self.positions:
                continue
            matched = True
            lower, upper = self.JOINT_LIMITS[name]
            self.positions[name] = min(max(float(position), lower), upper)
        if matched and not self._received_joint_state:
            self._received_joint_state = True
            self.get_logger().info("Received /joint_states; Gazebo joint commands are now following it")

    def _publish_commands(self):
        for name in self.joint_names:
            msg = Float64()
            msg.data = self.positions[name]
            self._cmd_publishers[name].publish(msg)


def main():
    rclpy.init()
    node = JointStateToGazeboJointCommand()
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    finally:
        node.destroy_node()
        if rclpy.ok():
            rclpy.shutdown()


if __name__ == "__main__":
    main()

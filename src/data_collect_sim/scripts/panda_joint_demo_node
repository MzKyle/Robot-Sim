#!/usr/bin/env python3
"""
Publish simple Panda joint position commands for Gazebo demos.
"""
import math

import rclpy
from rclpy.node import Node
from std_msgs.msg import Float64


class PandaJointDemoNode(Node):
    JOINTS = {
        "panda_joint1": {"offset": 0.0, "amplitude": 0.35, "phase": 0.0},
        "panda_joint2": {"offset": -0.45, "amplitude": 0.25, "phase": 0.7},
        "panda_joint3": {"offset": 0.0, "amplitude": 0.35, "phase": 1.4},
        "panda_joint4": {"offset": -1.35, "amplitude": 0.25, "phase": 2.1},
        "panda_joint5": {"offset": 0.0, "amplitude": 0.30, "phase": 2.8},
        "panda_joint6": {"offset": 1.1, "amplitude": 0.25, "phase": 3.5},
        "panda_joint7": {"offset": 0.0, "amplitude": 0.35, "phase": 4.2},
    }

    def __init__(self):
        super().__init__("panda_joint_demo")
        self.declare_parameter("model_name", "panda_weld_arm")
        self.declare_parameter("publish_rate", 30.0)
        self.declare_parameter("motion_period", 12.0)

        self.model_name = self.get_parameter("model_name").value
        publish_rate = max(1.0, float(self.get_parameter("publish_rate").value))
        self.motion_period = max(1.0, float(self.get_parameter("motion_period").value))
        self.tick = 0
        self.joint_publishers = {
            joint_name: self.create_publisher(
                Float64,
                f"/{self.model_name}/joint/{joint_name}/cmd_pos",
                10,
            )
            for joint_name in self.JOINTS
        }
        self.create_timer(1.0 / publish_rate, self._publish_commands)
        self.get_logger().info(f"Publishing Panda demo joint commands for {self.model_name}")

    def _publish_commands(self):
        phase = self.tick * (2.0 * math.pi / self.motion_period)
        for joint_name, config in self.JOINTS.items():
            msg = Float64()
            msg.data = float(
                config["offset"] + config["amplitude"] * math.sin(phase + config["phase"])
            )
            self.joint_publishers[joint_name].publish(msg)
        self.tick += 1


def main():
    rclpy.init()
    node = PandaJointDemoNode()
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    finally:
        node.destroy_node()
        if rclpy.ok():
            rclpy.shutdown()


if __name__ == "__main__":
    main()

#!/usr/bin/env python3
"""
Log Gazebo model state after startup so GUI visibility is not the only signal.
"""
import subprocess

import rclpy
from rclpy.node import Node


class CheckGzModelNode(Node):
    def __init__(self):
        super().__init__("check_gz_model")
        self.declare_parameter("model_name", "panda_weld_arm")
        self.declare_parameter("world_name", "weld_cell")
        self.declare_parameter("check_delay", 6.0)
        self.model_name = self.get_parameter("model_name").value
        self.world_name = self.get_parameter("world_name").value
        self._checked = False
        self.create_timer(float(self.get_parameter("check_delay").value), self._check_once)

    def _check_once(self):
        if self._checked:
            return
        self._checked = True

        cmd = ["gz", "model", "-m", self.model_name, "-p"]
        try:
            result = subprocess.run(cmd, check=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)
            info = result.stdout.strip() or "model query returned no text"
            self.get_logger().info(f"Gazebo model [{self.model_name}] info: {info}")
        except subprocess.CalledProcessError as exc:
            stderr = exc.stderr.strip() or exc.stdout.strip()
            self.get_logger().error(f"Gazebo model [{self.model_name}] not found: {stderr}")
        finally:
            rclpy.shutdown()


def main():
    rclpy.init()
    node = CheckGzModelNode()
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass


if __name__ == "__main__":
    main()

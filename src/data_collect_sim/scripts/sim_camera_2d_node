#!/usr/bin/env python3

import math

import numpy as np

import rclpy
from rclpy.node import Node
from sensor_msgs.msg import Image
from rcl_interfaces.msg import SetParametersResult


class SimCamera2DNode(Node):
    def __init__(self):
        super().__init__("camera_node")

        self.declare_parameter("trigger_mode", 2)
        self.declare_parameter("strobe_polarity", 0)
        self.declare_parameter("saturation", 64)
        self.declare_parameter("gamma", 106)
        self.declare_parameter("exposure_time", 4.3)
        self.declare_parameter("analog_gain", 64)
        self.declare_parameter("frame_rate", 30.0)
        self.declare_parameter("image_width", 960)
        self.declare_parameter("image_height", 540)

        self.publisher = self.create_publisher(Image, "/image_topic", 1)
        self.frame_index = 0
        self.settings = self._read_settings()
        self.timer = self.create_timer(1.0 / self.settings["frame_rate"], self._tick)
        self.add_on_set_parameters_callback(self._on_parameters)

    def _read_settings(self):
        frame_rate = max(1.0, float(self.get_parameter("frame_rate").value))
        return {
            "trigger_mode": int(self.get_parameter("trigger_mode").value),
            "strobe_polarity": int(self.get_parameter("strobe_polarity").value),
            "saturation": int(self.get_parameter("saturation").value),
            "gamma": int(self.get_parameter("gamma").value),
            "exposure_time": float(self.get_parameter("exposure_time").value),
            "analog_gain": int(self.get_parameter("analog_gain").value),
            "frame_rate": frame_rate,
            "width": int(self.get_parameter("image_width").value),
            "height": int(self.get_parameter("image_height").value),
        }

    def _on_parameters(self, parameters):
        for parameter in parameters:
            if parameter.name == "frame_rate":
                value = max(1.0, float(parameter.value))
                self.settings["frame_rate"] = value
                self.timer.cancel()
                self.timer = self.create_timer(1.0 / value, self._tick)
            elif parameter.name in self.settings:
                self.settings[parameter.name] = parameter.value
        return SetParametersResult(successful=True)

    def _build_frame(self):
        width = self.settings["width"]
        height = self.settings["height"]
        phase = self.frame_index * 0.12

        x = np.linspace(0.0, 1.0, width, dtype=np.float32)
        y = np.linspace(0.0, 1.0, height, dtype=np.float32)[:, None]

        blue = 95.0 + 60.0 * np.sin(2.3 * x + phase) + 35.0 * (1.0 - y)
        green = 120.0 + 40.0 * np.cos(1.7 * y + phase) + 25.0 * x
        red = 75.0 + 120.0 * np.exp(-((x - 0.5 - 0.12 * math.sin(phase * 0.4)) ** 2) / 0.012)
        red = red + 30.0 * np.sin(4.0 * y + phase)

        frame = np.stack([blue, green, red], axis=-1)
        frame = np.clip(frame, 0, 255).astype(np.uint8)

        seam_center = int(width * (0.34 + 0.16 * math.sin(phase * 0.5)))
        seam_half = max(2, width // 220)
        seam_left = max(0, seam_center - seam_half)
        seam_right = min(width, seam_center + seam_half)
        frame[:, seam_left:seam_right, 0] = 20
        frame[:, seam_left:seam_right, 1] = 20
        frame[:, seam_left:seam_right, 2] = 240

        band_top = int(height * 0.55 + height * 0.08 * math.sin(phase * 0.7))
        band_bottom = min(height, band_top + max(12, height // 18))
        band = frame[band_top:band_bottom, :, 1].astype(np.int16) + 35
        frame[band_top:band_bottom, :, 1] = np.clip(band, 0, 255).astype(np.uint8)

        return frame

    def _tick(self):
        frame = self._build_frame()
        msg = Image()
        msg.header.stamp = self.get_clock().now().to_msg()
        msg.header.frame_id = "camera_frame"
        msg.height = frame.shape[0]
        msg.width = frame.shape[1]
        msg.encoding = "bgr8"
        msg.is_bigendian = False
        msg.step = frame.shape[1] * 3
        msg.data = frame.tobytes()
        self.publisher.publish(msg)
        self.frame_index += 1


def main():
    rclpy.init()
    node = SimCamera2DNode()
    try:
        rclpy.spin(node)
    finally:
        node.destroy_node()
        rclpy.shutdown()


if __name__ == "__main__":
    main()
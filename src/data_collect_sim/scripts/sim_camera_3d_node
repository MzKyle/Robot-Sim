#!/usr/bin/env python3

import math

import numpy as np

import rclpy
from rcl_interfaces.msg import SetParametersResult
from rclpy.node import Node
from sensor_msgs.msg import Image, PointCloud2
from sensor_msgs_py import point_cloud2
from std_srvs.srv import Empty, Trigger
from std_msgs.msg import Header
from weld_interface.msg import TcpPos
from weld_interface.srv import Scan3d


class SimCamera3DNode(Node):
    def __init__(self):
        super().__init__("camera_driver_3d")

        defaults = {
            "cfg": "config/cameratcp_sim.yaml",
            "publish_tf": True,
            "camera.x": -0.0240785,
            "camera.y": 0.183801,
            "camera.z": 0.495747,
            "camera.rx": -3.00009,
            "camera.ry": 0.0952431,
            "camera.rz": 2.80206,
            "tool.x": 0.0,
            "tool.y": 0.0,
            "tool.z": 0.0,
            "tool.rx": 0.0,
            "tool.ry": 0.0,
            "tool.rz": 0.0,
            "y_min": -0.015,
            "y_max": 0.015,
            "z_min": -0.035,
            "z_max": 0.015,
            "y_min_f": -0.002,
            "y_max_f": 0.007,
            "percentile_low": 0.333,
            "percentile_high": 0.666,
            "number_points_threshold": 25,
            "no_detection_count_threshold": 3,
            "target_height": 0.0,
            "scan_rate": 10.0,
        }
        self._parameter_keys = list(defaults.keys())
        for key, value in defaults.items():
            self.declare_parameter(key, value)

        self.cloud_pub = self.create_publisher(PointCloud2, "/tcp_cloud_raw", 1)
        self.scan_pose_pub = self.create_publisher(TcpPos, "/scan_pose", 1)
        self.fixed_scan_pub = self.create_publisher(PointCloud2, "/fixed_scan", 1)
        self.fixed_scan_all_pub = self.create_publisher(PointCloud2, "/fixed_scan_all", 1)
        self.debug_height_pub = self.create_publisher(Image, "/debug_height_img", 1)

        self.scan_enabled = True
        self.tick = 0
        self.settings = self._read_settings()
        self.timer = self.create_timer(1.0 / self.settings["scan_rate"], self._tick)
        self.add_on_set_parameters_callback(self._on_parameters)

        self.create_service(Empty, "/start_fix_scan", self._start_fix_scan)
        self.create_service(Empty, "/stop_fix_scan", self._stop_fix_scan)
        self.create_service(Scan3d, "scan_3d", self._scan_once)
        self.create_service(Trigger, "/reload_camera_3d_config", self._reload_config)

    def _read_settings(self):
        settings = {name: self.get_parameter(name).value for name in self._parameter_keys}
        settings["scan_rate"] = max(1.0, float(settings.get("scan_rate", 10.0)))
        settings["y_min"] = float(settings.get("y_min", -0.015))
        settings["y_max"] = float(settings.get("y_max", 0.015))
        settings["z_min"] = float(settings.get("z_min", -0.035))
        settings["z_max"] = float(settings.get("z_max", 0.015))
        settings["target_height"] = float(settings.get("target_height", 0.0))
        return settings

    def _on_parameters(self, parameters):
        restart_timer = False
        for parameter in parameters:
            self.settings[parameter.name] = parameter.value
            if parameter.name == "scan_rate":
                restart_timer = True

        if restart_timer:
            rate = max(1.0, float(self.settings["scan_rate"]))
            self.timer.cancel()
            self.timer = self.create_timer(1.0 / rate, self._tick)
            self.settings["scan_rate"] = rate

        return SetParametersResult(successful=True)

    def _make_points(self, dense=False):
        y_min = float(self.settings["y_min_f"] if dense else self.settings["y_min"])
        y_max = float(self.settings["y_max_f"] if dense else self.settings["y_max"])
        z_base = float(self.settings["target_height"])

        x_values = np.linspace(-0.18, 0.18, 72 if dense else 56)
        y_values = np.linspace(y_min, y_max, 54 if dense else 42)
        phase = self.tick * 0.08

        points = []
        for x in x_values:
            seam_offset = 0.02 * math.sin(phase * 0.7 + x * 8.0)
            for y in y_values:
                ridge = 0.015 * math.exp(-((x - seam_offset) ** 2) / 0.0025)
                ripple = 0.003 * math.sin(phase + x * 10.0 + y * 18.0)
                z = z_base + 0.32 + ridge + ripple
                points.append((float(x), float(y), float(z)))
        return points

    def _build_cloud(self, dense=False):
        points = self._make_points(dense=dense)
        header = Header()
        header.stamp = self.get_clock().now().to_msg()
        header.frame_id = "camera_3d_link"
        return point_cloud2.create_cloud_xyz32(
            header=header,
            points=points,
        )

    def _build_debug_image(self):
        height = 240
        width = 360
        phase = self.tick * 0.08
        x = np.linspace(0.0, 1.0, width, dtype=np.float32)
        y = np.linspace(0.0, 1.0, height, dtype=np.float32)[:, None]
        surface = 140.0 + 80.0 * np.sin(4.0 * x + phase) + 55.0 * np.cos(3.0 * y + phase)
        surface = np.clip(surface, 0, 255).astype(np.uint8)
        image = np.stack([surface, np.flipud(surface), surface], axis=-1)

        msg = Image()
        msg.header.stamp = self.get_clock().now().to_msg()
        msg.header.frame_id = "camera_3d_link"
        msg.height = image.shape[0]
        msg.width = image.shape[1]
        msg.encoding = "bgr8"
        msg.is_bigendian = False
        msg.step = image.shape[1] * 3
        msg.data = image.tobytes()
        return msg

    def _publish_bundle(self, dense=False):
        cloud = self._build_cloud(dense=dense)
        pose = TcpPos()
        phase = self.tick * 0.08
        pose.x = 0.12 * math.sin(phase)
        pose.y = 0.03 * math.cos(phase * 0.8)
        pose.z = 0.48 + 0.015 * math.sin(phase * 0.5)
        pose.rx = -3.0
        pose.ry = 0.1 * math.sin(phase * 0.3)
        pose.rz = 2.8 + 0.03 * math.cos(phase * 0.6)
        pose.e1 = 0.0
        pose.e2 = 0.0
        pose.e3 = 0.0

        self.cloud_pub.publish(cloud)
        self.fixed_scan_pub.publish(cloud)
        self.fixed_scan_all_pub.publish(self._build_cloud(dense=True))
        self.scan_pose_pub.publish(pose)
        self.debug_height_pub.publish(self._build_debug_image())

    def _tick(self):
        if self.scan_enabled:
            self._publish_bundle(dense=False)
        self.tick += 1

    def _start_fix_scan(self, request, response):
        self.scan_enabled = True
        response.success = True
        response.message = "fixed scan enabled"
        return response

    def _stop_fix_scan(self, request, response):
        self.scan_enabled = False
        response.success = True
        response.message = "fixed scan disabled"
        return response

    def _scan_once(self, request, response):
        response.image = self._build_debug_image()
        response.points = self._build_cloud(dense=True)
        return response

    def _reload_config(self, request, response):
        self.settings = self._read_settings()
        response.success = True
        response.message = "camera_3d config reloaded"
        return response


def main():
    rclpy.init()
    node = SimCamera3DNode()
    try:
        rclpy.spin(node)
    finally:
        node.destroy_node()
        rclpy.shutdown()


if __name__ == "__main__":
    main()